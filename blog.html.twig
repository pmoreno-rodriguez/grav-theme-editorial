{% extends 'partials/base.html.twig' %}

{% block body %}
    <section>
        <header class="main">
            <h1>{{ page.title }}</h1>
        </header>
        <div class="posts">
            {% set collection = page.collection() %}

            {% for child in collection %}
                    {% include 'partials/blog-list-item.html.twig' with {blog: page, page: child} %}
            {% endfor %}
        </div>
    </section><!-- End section -->
{% endblock %}
