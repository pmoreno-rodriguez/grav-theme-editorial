<section>
<header class="major">
    <h2>{{ page.title }}</h2>
</header>
    {{ content|raw }}

    <div class="features">
    {% for feature in page.header.features %}
        <article>
            
                {% if feature.icon %}<span class="icon {{feature.icon}}"></span>{% endif %}
                <div class="content">
                    {% if feature.title %}<h3>{{feature.title}}</h3>{% endif %}
                    {% if feature.url %}<a href="{{feature.url}}" target="_blank">{% if feature.title %}<h3>{{feature.title}}</h3>{% endif %}{% endif %}
                    {% if feature.text %}<p>{{feature.text}}</p>{% endif %}
                </div>
            
        </article>
    {% endfor %}
     </div>
</section>